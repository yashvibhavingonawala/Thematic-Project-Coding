APP_NAME=MovieCrew API
APP_ENV=dev

# Where your frontend runs (so the browser is allowed to call the API)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Database type:
# - sqlite (recommended for easy local setup)
# - mysql (optional later)
DB_TYPE=sqlite

# SQLite file path (relative or absolute)
SQLITE_PATH=./data/movie_db.sqlite3

# MySQL connection (only used if DB_TYPE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=movie_db

# Server settings
API_HOST=127.0.0.1
API_PORT=8000

# Sessions
SESSION_SECRET_KEY=dev-change-me

# TMDB (optional but recommended for downloading posters)
TMDB_API_KEY=

APP_NAME=MovieScope API
APP_ENV=dev

# Where your frontend runs (so the browser is allowed to call the API)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500

# Database type:
# - sqlite (recommended for easy local setup)
# - mysql (optional later)
DB_TYPE=sqlite

# SQLite file path (relative or absolute)
SQLITE_PATH=./data/movie_db.sqlite3

# MySQL connection (only used if DB_TYPE=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=movie_db

# Server settings
API_HOST=127.0.0.1
API_PORT=8000
